# Interview Platform Microservices
# Environment variables configuration

# Service URLs (override these in production)
RESUME_PARSER_URL=http://localhost:8001
PROFILE_MATCHING_URL=http://localhost:8002

# File upload settings
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# API settings
API_PREFIX=/api
DEBUG=true

# CORS - in production, replace with specific origins
CORS_ORIGINS=["*"]
