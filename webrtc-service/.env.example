# Server
SIGNALING_PORT=9000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# PeerJS Server path
PEERJS_PATH=/peerjs

# Room constraints
MAX_ROOM_SIZE=2

# TURN Server (Production)
# TURN_URL=
# TURN_USERNAME=
# TURN_CREDENTIAL=
