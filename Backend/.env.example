# Server Configuration
PORT=8002
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
DB_NAME=jobsaarthi

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=jobsaarthi
POSTGRES_SSL=false

# JWT Configuration
JWT_SECRET=
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRE=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Request body limit for code execution payloads
REQUEST_BODY_LIMIT=256kb

# Redis / BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false

# Code execution sandbox
CODE_EXECUTION_TIMEOUT_MS=5000
CODE_EXECUTION_MEMORY_LIMIT=128m
CODE_EXECUTION_CPU_LIMIT=0.5
CODE_EXECUTION_WORKER_CONCURRENCY=4
CODE_EXECUTION_MAX_SOURCE_BYTES=65536
CODE_EXECUTION_MAX_STDIN_BYTES=32768
CODE_EXECUTION_MAX_OUTPUT_BYTES=65536
CODE_EXECUTION_JOB_RETENTION_SECONDS=3600
CODE_EXECUTION_NODE_IMAGE=node:20-alpine
CODE_EXECUTION_PYTHON_IMAGE=python:3.12-alpine
CODE_EXECUTION_CPP_IMAGE=gcc:14
CODE_EXECUTION_JAVA_IMAGE=openjdk:21-jdk-slim
